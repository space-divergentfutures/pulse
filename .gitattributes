# Normalize line endings: LF in the repository for all text files.
* text=auto eol=lf

# Explicit text types
*.py   text eol=lf
*.md   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.ini  text eol=lf
*.txt  text eol=lf

# Binary assets — never normalize
*.png binary
*.jpg binary
*.ico binary
